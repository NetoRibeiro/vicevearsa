{
  "name": "vicevearsa",
  "version": "1.1.0",
  "description": "Multi-agent orchestration framework — create AI departments that work together",
  "type": "module",
  "bin": {
    "vicevearsa": "bin/vicevearsa.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/ bin/ tests/",
    "version": "node -e \"require('fs').writeFileSync('templates/_vicevearsa/.vicevearsa-version', require('./package.json').version + '\\n')\" && git add templates/_vicevearsa/.vicevearsa-version"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "departments"
  ],
  "author": "Neto Ribeiro (https://github.com/netoribeiro)",
  "homepage": "https://github.com/netoribeiro/vicevearsa#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/netoribeiro/vicevearsa.git"
  },
  "bugs": {
    "url": "https://github.com/netoribeiro/vicevearsa/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "templates/"
  ],
  "dependencies": {
    "@inquirer/checkbox": "^5.1.0",
    "@inquirer/input": "^5.0.0",
    "@inquirer/select": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0"
  }
}
